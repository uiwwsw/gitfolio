{
  "name": "githubprint",
  "version": "0.1.0",
  "description": "Turn GitHub into a shareable, PDF-ready developer brief.",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10"
  },
  "keywords": [
    "nextjs",
    "github",
    "portfolio",
    "developer-profile",
    "openai",
    "pdf"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test:resume": "node --import tsx --test tests/resume.test.ts",
    "check": "npm run build && npm run typecheck && npm run quality:regress",
    "insights:aggregate": "node scripts/aggregate-insights.mjs",
    "quality:regress": "node scripts/run-quality-regressions.cjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "next": "16.1.7",
    "openai": "^6.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.3.1",
    "yaml": "^2.8.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.16",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "tailwindcss": "^4.1.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
